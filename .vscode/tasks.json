{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start PostgreSQL",
      "type": "shell",
      "command": "docker compose up -d",
      "problemMatcher": []
    },
    {
      "label": "Run Backend API",
      "type": "shell",
      "command": "dotnet run --project backend/src/DeliveryApp.Api/DeliveryApp.Api.csproj",
      "dependsOn": "Start PostgreSQL",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend/delivery-driver-web"
      },
      "problemMatcher": []
    }
  ]
}
