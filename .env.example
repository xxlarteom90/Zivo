# ASP.NET Core can read these if you export them before running the API.
# For local PostgreSQL, run `npm run db:setup` to create this user/database.
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=delivery_app;Username=delivery_app;Password=delivery_app_dev_password
Jwt__Issuer=DeliveryApp
Jwt__Audience=DeliveryApp.Client
Jwt__SigningKey=LOCAL_DEV_ONLY_SUPER_SECRET_SIGNING_KEY_1234567890
Jwt__AccessTokenMinutes=480
Database__ApplyMigrationsOnStartup=true
Database__SeedDemoData=true
